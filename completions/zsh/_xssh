#compdef xssh

# Zsh completion for xssh — reuses ssh's completer verbatim so hostname
# completion picks up everything in ~/.ssh/config, known_hosts, /etc/hosts,
# and all of ssh's own flags. The session-management subcommands (ls/kill/
# rm) intentionally aren't completed; they take session IDs (random hex)
# that aren't worth special-casing.
#
# Install:
#   System: copy to /usr/share/zsh/site-functions/_xssh
#   User:   copy to a dir in $fpath, e.g. ~/.zsh/completions/_xssh, and
#           ensure that dir is in fpath BEFORE `compinit` runs.

_xssh() {
    # Suppress host completion for the bare-subcommand forms.
    case "${words[2]}" in
        ls|kill|rm|help|--help|-h) return ;;
    esac
    _ssh "$@"
}

_xssh "$@"
